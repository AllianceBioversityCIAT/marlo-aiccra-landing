---
import { footerLinks } from '../../data/navigation';
---

<footer style="background-color: #0f2a47;" class="text-white">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Brand -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src="/marlo-logo.png" alt="MARLO logo" class="w-8 h-8 object-contain" />
        <div class="flex flex-col leading-none">
          <span
            id="logo-marlo"
            class="text-base font-bold text-white transition-colors duration-300"
          >
            MARLO
          </span>
          <!-- <span id="logo-sub" class="text-[10px] font-medium text-white/70 transition-colors duration-300">For reporting & monitoring evaluation</span> -->
        </div>
      </a>

      <!-- Links -->
      <nav>
        <ul class="flex flex-wrap gap-6">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  target={link.href.includes('https') ? '_blank' : '_self'}
                  rel={link.href.includes('https') ? 'noopener noreferrer' : ''}
                  href={link.href}
                  class="text-sm transition-colors"
                  style="color: rgba(255,255,255,0.7);"
                  onmouseover="this.style.color='white'"
                  onmouseout="this.style.color='rgba(255,255,255,0.7)'"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3"
      style="border-top: 1px solid rgba(255,255,255,0.1);"
    >
      <p class="text-xs" style="color: rgba(255,255,255,0.4);">
        &copy; {new Date().getFullYear()} CGIAR AICCRA. All rights reserved.
      </p>
      <p class="text-xs" style="color: rgba(255,255,255,0.4);">
        Designed for complex program environments
      </p>
    </div>
  </div>
</footer>
