---
import { footerLinks } from '../../data/navigation';
---

<footer style="background-color: #0f2a47;" class="text-white">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Brand -->
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #1a3a5c, #2563eb);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-base font-bold">MARLO</span>
        </div>
        <p class="text-sm max-w-xs" style="color: rgba(255,255,255,0.6);">
          Structured reporting and performance management for complex programs.
        </p>
      </div>

      <!-- Links -->
      <nav>
        <ul class="flex flex-wrap gap-6">
          {footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors"
                style="color: rgba(255,255,255,0.7);"
                onmouseover="this.style.color='white'"
                onmouseout="this.style.color='rgba(255,255,255,0.7)'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
      <p class="text-xs" style="color: rgba(255,255,255,0.4);">
        &copy; {new Date().getFullYear()} CGIAR AICCRA. All rights reserved.
      </p>
      <p class="text-xs" style="color: rgba(255,255,255,0.4);">
        Designed for complex program environments
      </p>
    </div>
  </div>
</footer>
