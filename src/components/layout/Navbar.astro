---
import { navLinks } from '../../data/navigation';
import { Menu } from '@lucide/astro';
---

<header
  id="main-header"
  class="sticky top-0 z-50 transition-[background-color,box-shadow,color] duration-300"
  style="background-color: #012E4A;"
>
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src="/marlo-logo.png" alt="MARLO logo" class="w-8 h-8 object-contain" />
      <div class="flex flex-col leading-none">
        <span id="logo-marlo" class="text-base font-bold text-white transition-colors duration-300">
          MARLO
        </span>
        <!-- <span id="logo-sub" class="text-[10px] font-medium text-white/70 transition-colors duration-300">For reporting & monitoring evaluation</span> -->
      </div>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-6">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link text-sm font-medium text-white hover:text-[#22D3EE] transition-colors duration-300"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Right Actions -->
    <div class="flex items-center gap-4">
      <a
        href="#"
        id="docs-link"
        class="hidden md:block text-sm font-medium text-white hover:text-[#22D3EE] transition-colors duration-300"
      >
        Documentation
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold text-white transition-colors"
        style="background-color: #2563eb;"
        onmouseover="this.style.backgroundColor='#1d4ed8'"
        onmouseout="this.style.backgroundColor='#2563eb'"
      >
        Request a Demo
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-white hover:bg-white/10 transition-colors duration-300"
        aria-label="Open menu"
      >
        <Menu size={20} />
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/20 bg-[#012E4A] px-6 py-4">
    <ul class="flex flex-col gap-3">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link text-sm font-medium text-white hover:text-[#22D3EE]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="#" class="mobile-nav-link text-sm font-medium text-white hover:text-[#22D3EE]"
          >Documentation</a
        >
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  const header = document.getElementById('main-header');
  const logoMarlo = document.getElementById('logo-marlo');
  const logoSub = document.getElementById('logo-sub');
  const navLinks = document.querySelectorAll('.nav-link');
  const docsLink = document.getElementById('docs-link');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  function updateNavbar() {
    const scrolled = window.scrollY > 50;

    if (scrolled) {
      header?.classList.add('bg-white');
      header?.style.removeProperty('background-color');
      header?.style.setProperty('box-shadow', '0 1px 0 0 #e5e7eb, 0 1px 3px 0 rgb(0 0 0 / 0.1)');

      logoMarlo?.classList.remove('text-white');
      logoMarlo?.style.setProperty('color', '#1a3a5c');
      logoSub?.classList.remove('text-white/70');
      logoSub?.style.setProperty('color', '#6b7280');

      navLinks.forEach((link) => {
        link.classList.remove('text-white', 'hover:text-[#22D3EE]');
        link.classList.add('text-gray-600', 'hover:text-[#1a3a5c]');
      });

      docsLink?.classList.remove('text-white', 'hover:text-[#22D3EE]');
      docsLink?.classList.add('text-gray-600', 'hover:text-[#1a3a5c]');

      mobileBtn?.classList.remove('text-white', 'hover:bg-white/10');
      mobileBtn?.classList.add('text-gray-600', 'hover:bg-gray-100');

      if (mobileMenu && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.remove('bg-[#012E4A]', 'border-white/20');
        mobileMenu.classList.add('bg-white', 'border-gray-200');
        mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
          link.classList.remove('text-white', 'hover:text-[#22D3EE]');
          link.classList.add('text-gray-600', 'hover:text-[#1a3a5c]');
        });
      }
    } else {
      header?.classList.remove('bg-white');
      header?.style.setProperty('background-color', '#012E4A');
      header?.style.setProperty('box-shadow', 'none');

      logoMarlo?.style.removeProperty('color');
      logoMarlo?.classList.add('text-white');
      logoSub?.style.removeProperty('color');
      logoSub?.classList.add('text-white/70');

      navLinks.forEach((link) => {
        link.classList.add('text-white', 'hover:text-[#22D3EE]');
        link.classList.remove('text-gray-600', 'hover:text-[#1a3a5c]');
      });

      docsLink?.classList.add('text-white', 'hover:text-[#22D3EE]');
      docsLink?.classList.remove('text-gray-600', 'hover:text-[#1a3a5c]');

      mobileBtn?.classList.add('text-white', 'hover:bg-white/10');
      mobileBtn?.classList.remove('text-gray-600', 'hover:bg-gray-100');
    }
  }

  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();
</script>
