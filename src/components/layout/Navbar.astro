---
import { navLinks } from '../../data/navigation';
import { Layers, Menu } from '@lucide/astro';
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #1a3a5c, #2563eb);">
        <Layers size={18} color="white" />
      </div>
      <div class="flex flex-col leading-none">
        <span class="text-base font-bold" style="color: #1a3a5c;">
          MARLO <span style="color: #2563eb;">AICCRA</span>
        </span>
        <span class="text-[10px] font-medium" style="color: #6b7280;">Research Management</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-6">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-gray-600 hover:text-[#1a3a5c] transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right Actions -->
    <div class="flex items-center gap-4">
      <a
        href="#"
        class="hidden md:block text-sm font-medium text-gray-600 hover:text-[#1a3a5c] transition-colors"
      >
        Documentation
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold text-white transition-colors"
        style="background-color: #2563eb;"
        onmouseover="this.style.backgroundColor='#1d4ed8'"
        onmouseout="this.style.backgroundColor='#2563eb'"
      >
        Request a Demo
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-gray-600 hover:bg-gray-100"
        aria-label="Open menu"
      >
        <Menu size={20} />
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-200 bg-white px-6 py-4">
    <ul class="flex flex-col gap-3">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="text-sm font-medium text-gray-600 hover:text-[#1a3a5c]">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="#" class="text-sm font-medium text-gray-600 hover:text-[#1a3a5c]">Documentation</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
