---
import { BarChart2, Globe, Bot, Download, MessageSquare } from '@lucide/astro';

const capabilities = [
  {
    Icon: BarChart2,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'Real-Time Dashboards',
    desc: 'Continuous program monitoring with up-to-date dashboards across all reporting phases.',
  },
  {
    Icon: Globe,
    iconColor: '#0d9488',
    iconBg: 'rgba(13,148,136,0.1)',
    title: 'Aggregated Insights',
    desc: 'Aggregated insights across projects, regions, and indicators for strategic decision-making.',
  },
  {
    Icon: Bot,
    iconColor: '#7c3aed',
    iconBg: 'rgba(124,58,237,0.1)',
    title: 'AI Chatbot',
    desc: 'Quickly access and explore reporting information through a conversational AI interface.',
  },
  {
    Icon: Download,
    iconColor: '#059669',
    iconBg: 'rgba(5,150,105,0.1)',
    title: 'Exportable Reports',
    desc: 'Generate and export reports for donors and stakeholders, aligned with your reporting frameworks.',
  },
];
---

<section id="intelligence" style="background: #f3f4f6;" class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Dashboard visual -->
      <div class="relative">
        <div class="rounded-3xl overflow-hidden shadow-xl" style="background: white; border: 1px solid #e5e7eb;">
          <!-- Header bar -->
          <div class="px-5 py-4 flex items-center justify-between" style="background: #1a3a5c;">
            <div class="flex items-center gap-3">
              <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(255,255,255,0.2);">
                <BarChart2 size={13} color="white" />
              </div>
              <div>
                <div class="text-xs font-semibold text-white">Intelligence Dashboard</div>
                <div class="text-[10px]" style="color: rgba(255,255,255,0.6);">Live · Program Overview</div>
              </div>
            </div>
            <div class="flex items-center gap-1.5 px-2 py-1 rounded-full text-[10px] font-semibold" style="background: rgba(34,211,238,0.15); color: #22d3ee;">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>
              AI Active
            </div>
          </div>

          <!-- Dashboard body -->
          <div class="p-5 flex flex-col gap-4">
            <!-- Trend chart -->
            <div>
              <div class="text-[10px] font-semibold mb-3 tracking-wider uppercase" style="color: #9ca3af;">Reporting Progress</div>
              <div class="flex items-end gap-1.5 h-16">
                {[40, 55, 45, 70, 60, 80, 75, 90, 85, 95].map((h, i) => (
                  <div
                    class="flex-1 rounded-t"
                    style={`height: ${h}%; background: ${i === 9 ? '#2563eb' : i >= 7 ? 'rgba(37,99,235,0.5)' : 'rgba(37,99,235,0.15)'};`}
                  />
                ))}
              </div>
            </div>

            <!-- AI chatbot hint -->
            <div class="rounded-xl p-3 flex gap-3 items-start" style="background: #f0f9ff; border: 1px solid #bfdbfe;">
              <div class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0" style="background: #2563eb;">
                <MessageSquare size={12} color="white" />
              </div>
              <div>
                <div class="text-[10px] font-semibold mb-1" style="color: #1d4ed8;">AI Assistant</div>
                <p class="text-[10px] leading-snug" style="color: #1e40af;">
                  "Show me programs with reporting completion below 70%..."
                </p>
              </div>
            </div>

            <!-- Mini KPIs -->
            <div class="grid grid-cols-3 gap-2">
              {[
                { label: 'Reports', value: '142', color: '#2563eb' },
                { label: 'Indicators', value: '64', color: '#0d9488' },
                { label: 'Exported', value: '38', color: '#059669' },
              ].map(({ label, value, color }) => (
                <div class="rounded-xl p-3 text-center" style="background: #f9fafb;">
                  <div class="text-base font-bold" style={`color: ${color};`}>{value}</div>
                  <div class="text-[10px]" style="color: #9ca3af;">{label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Content + capability items -->
      <div class="flex flex-col gap-8">
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
            Intelligence & AI
          </p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="color: #111827;">
            From structured reporting<br />to accessible insights
          </h2>
          <p class="text-sm leading-relaxed" style="color: #4b5563;">
            MARLO enhances structured reporting with integrated intelligence and AI-powered tools
            designed to simplify how users access, explore, and extract information from reported data.
          </p>
        </div>

        <!-- Capability items -->
        <div class="flex flex-col gap-4">
          {capabilities.map(({ Icon, iconColor, iconBg, title, desc }) => (
            <div class="flex gap-4 items-start">
              <div
                class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 mt-0.5"
                style={`background: ${iconBg};`}
              >
                <Icon size={16} color={iconColor} />
              </div>
              <div>
                <h3 class="text-sm font-bold mb-1" style="color: #111827;">{title}</h3>
                <p class="text-xs leading-relaxed" style="color: #6b7280;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
