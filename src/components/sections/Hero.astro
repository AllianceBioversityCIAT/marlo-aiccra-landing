---
---

<section
  id="home"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
  style="background: linear-gradient(135deg, #1a3a5c 0%, #0f2a47 60%, #0a1e33 100%);"
>
  <!-- Background dots pattern -->
  <div class="absolute inset-0 opacity-10"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 32px 32px;">
  </div>

  <div class="relative max-w-7xl mx-auto px-6 py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left content -->
      <div class="flex flex-col gap-8">
        <!-- Partner badges -->
        <div class="flex flex-wrap gap-2">
          {['CGIAR', 'AICCRA', 'WORLD BANK IDA'].map((badge) => (
            <span
              class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold tracking-wide"
              style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.2);"
            >
              {badge}
            </span>
          ))}
        </div>

        <!-- Headline -->
        <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-white leading-tight">
          Transforming<br />
          Agricultural<br />
          Research into<br />
          <em class="not-italic" style="color: #60a5fa; font-style: italic;">Measurable Impact</em>
        </h1>

        <!-- Description -->
        <div class="flex flex-col gap-3">
          <p class="text-base lg:text-lg leading-relaxed" style="color: rgba(255,255,255,0.75);">
            MARLO AICCRA is a strategic results management platform designed to plan, track, and scale innovation-driven research portfolios across Africa.
          </p>
          <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.6);">
            It connects planning, implementation, adaptive management, and reporting into an integrated system that supports evidence-based decision-making.
          </p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a
            href="#"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold text-white transition-all"
            style="background-color: #2563eb; border: 2px solid #2563eb;"
            onmouseover="this.style.backgroundColor='#1d4ed8'; this.style.borderColor='#1d4ed8';"
            onmouseout="this.style.backgroundColor='#2563eb'; this.style.borderColor='#2563eb';"
          >
            Access MARLO
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold transition-all"
            style="background: transparent; border: 2px solid rgba(255,255,255,0.4); color: rgba(255,255,255,0.9);"
            onmouseover="this.style.backgroundColor='rgba(255,255,255,0.1)'"
            onmouseout="this.style.backgroundColor='transparent'"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10,8 16,12 10,16"/></svg>
            Explore Documentation
          </a>
        </div>
      </div>

      <!-- Right: Dashboard mockup -->
      <div class="hidden lg:block">
        <div
          class="rounded-2xl p-1 shadow-2xl"
          style="background: linear-gradient(135deg, rgba(37,99,235,0.3), rgba(13,148,136,0.2)); border: 1px solid rgba(255,255,255,0.1);"
        >
          <div class="rounded-xl p-6 flex flex-col gap-4" style="background: rgba(15, 42, 71, 0.95);">
            <!-- Header -->
            <div class="flex items-center justify-between pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: #1a3a5c; border: 1px solid rgba(255,255,255,0.1);">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold text-white">MARLO AICCRA Dashboard</div>
                  <div class="text-[10px]" style="color: rgba(255,255,255,0.5);">Annual Reporting Cycle: 2025</div>
                </div>
              </div>
              <div class="px-2 py-1 rounded text-[10px] font-semibold" style="background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.2);">
                ● Live
              </div>
            </div>

            <!-- New Innovation badge -->
            <div class="self-end px-3 py-2 rounded-lg text-xs" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
              <div class="flex items-center gap-1 mb-1">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
                <span style="color: #fbbf24;" class="font-semibold">New Innovation</span>
              </div>
              <p class="text-[10px]" style="color: rgba(255,255,255,0.6);">Drought-tolerant maize variety documented in Ghana cluster</p>
              <p class="text-[10px] mt-1" style="color: rgba(255,255,255,0.4);">Maturity: Scaling ↑</p>
            </div>

            <!-- Portfolio Completion -->
            <div>
              <div class="text-[10px] font-semibold mb-2 tracking-wide" style="color: rgba(255,255,255,0.5);">PORTFOLIO COMPLETION</div>
              {[
                { country: 'Senegal', pct: 87, color: '#2563eb' },
                { country: 'Ethiopia', pct: 92, color: '#2563eb' },
                { country: 'Kenya', pct: 78, color: '#2563eb' },
                { country: 'Ghana', pct: 96, color: '#10b981' },
              ].map(({ country, pct, color }) => (
                <div class="flex items-center gap-2 mb-1.5">
                  <div class="text-[10px] w-16 shrink-0" style="color: rgba(255,255,255,0.6);">{country}</div>
                  <div class="flex-1 h-1.5 rounded-full" style="background: rgba(255,255,255,0.08);">
                    <div class="h-1.5 rounded-full" style={`width: ${pct}%; background: ${color};`}></div>
                  </div>
                  <div class="text-[10px] font-semibold w-8 text-right" style="color: rgba(255,255,255,0.7);">{pct}%</div>
                </div>
              ))}
            </div>

            <!-- Report Status + Counts -->
            <div class="grid grid-cols-2 gap-3">
              <div class="p-3 rounded-lg" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                <div class="text-[10px] font-semibold mb-2 tracking-wide" style="color: rgba(255,255,255,0.5);">REPORT STATUS</div>
                {[
                  { label: 'Submitted', n: 18, color: '#10b981' },
                  { label: 'In Review', n: 6, color: '#f59e0b' },
                ].map(({ label, n, color }) => (
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-[10px]" style="color: rgba(255,255,255,0.6);">{label}</span>
                    <span class="text-[10px] font-bold" style={`color: ${color}`}>{n}</span>
                  </div>
                ))}
              </div>
              <div class="grid grid-rows-2 gap-2">
                {[
                  { value: '24', label: 'Innovations' },
                  { value: '8', label: 'Clusters' },
                ].map(({ value, label }) => (
                  <div class="p-2 rounded-lg flex flex-col items-center justify-center" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                    <span class="text-lg font-bold" style="color: #60a5fa;">{value}</span>
                    <span class="text-[9px]" style="color: rgba(255,255,255,0.5);">{label}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Avatar row -->
            <div class="flex items-center justify-between pt-2" style="border-top: 1px solid rgba(255,255,255,0.06);">
              <div class="flex -space-x-1.5">
                {['#2563eb','#0d9488','#7c3aed','#dc2626','#d97706'].map((bg) => (
                  <div class="w-6 h-6 rounded-full border" style={`background: ${bg}; border-color: #0f2a47;`}></div>
                ))}
                <div class="w-6 h-6 rounded-full border flex items-center justify-center text-[8px] font-semibold" style="background: rgba(255,255,255,0.1); border-color: #0f2a47; color: rgba(255,255,255,0.6);">+2</div>
              </div>
              <span class="text-[10px]" style="color: rgba(255,255,255,0.4);">6 country teams active</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div class="mt-16 pt-8 grid grid-cols-2 lg:grid-cols-4 gap-6" style="border-top: 1px solid rgba(255,255,255,0.1);">
      {[
        { value: '9M+', label: 'People Reached' },
        { value: '41', label: 'Validated Innovations' },
        { value: '6', label: 'Country Teams' },
        { value: '$60M', label: 'World Bank Portfolio' },
      ].map(({ value, label }) => (
        <div class="flex flex-col gap-1">
          <span class="text-2xl font-bold text-white">{value}</span>
          <span class="text-xs" style="color: rgba(255,255,255,0.5);">{label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
