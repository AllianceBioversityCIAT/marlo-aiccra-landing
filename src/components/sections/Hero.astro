---

---

<section
  id="home"
  class="relative min-h-[calc(100vh-64px)] flex flex-col justify-center overflow-hidden"
  style="background: #012E4A;"
>
  <!-- Background dots pattern -->
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 32px 32px;"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-6 py-24 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left content -->
      <div class="flex flex-col gap-8">
        <!-- Partner badges -->
        <!-- <div class="flex flex-wrap gap-2">
          <span
            class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-[11px] tracking-[0.18em] uppercase"
            style="background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.82); border: 1px solid rgba(255,255,255,0.18);"
          >
            <span class="h-2 w-2 rounded-full" style="background: #22c55e;"></span>
            <span>CGIAR</span>
            <span class="h-1 w-1 rounded-full" style="background: rgba(255,255,255,0.45);"></span>
            <span>AICCRA</span>
            <span class="h-1 w-1 rounded-full" style="background: rgba(255,255,255,0.45);"></span>
            <span>WORLD BANK IDA</span>
          </span>
        </div> -->

        <!-- Headline -->
        <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-white leading-tight">
          Transform reporting<br />
          into a<br />
          <em class="not-italic" style="color: #22D3EE; font-style: italic;">strategic asset</em>
        </h1>

        <!-- Description -->
        <div class="flex flex-col gap-3">
          <p class="text-base lg:text-lg leading-relaxed" style="color: rgba(255,255,255,0.75);">
            MARLO is a structured reporting and performance management platform designed for
            complex programs. It helps teams improve data quality, streamline reporting processes,
            and turn data into actionable insights for better decision-making.
          </p>
        </div>

        <!-- Value points -->
        <ul class="flex flex-col gap-2">
          {[
            'Standardize reporting across multiple projects and teams',
            'Reduce manual work and reporting errors',
            'Improve data visibility in real time',
            'Support evidence-based decision-making',
            'Align reporting with organizational frameworks (e.g., PRMS, donor requirements)',
          ].map((point) => (
            <li class="flex items-start gap-2.5 text-sm" style="color: rgba(255,255,255,0.75);">
              <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              {point}
            </li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold text-white transition-all"
            style="background-color: #0EA5E9; border: 2px solid #0EA5E9;"
            onmouseover="this.style.backgroundColor='#1d4ed8'; this.style.borderColor='#1d4ed8';"
            onmouseout="this.style.backgroundColor='#0EA5E9'; this.style.borderColor='#0EA5E9';"
          >
            Request a Demo
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
          <a
            href="#features"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold transition-all"
            style="background: transparent; border: 2px solid rgba(255,255,255,0.4); color: rgba(255,255,255,0.9);"
            onmouseover="this.style.backgroundColor='rgba(255,255,255,0.1)'"
            onmouseout="this.style.backgroundColor='transparent'"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><polygon points="10,8 16,12 10,16"
              ></polygon></svg
            >
            Explore the Platform
          </a>
        </div>
      </div>

      <!-- Right: Dashboard illustration -->
      <div class="hidden lg:flex justify-end items-center">
        <div class="relative w-full max-w-[480px] py-10 px-12 hero-float">
          <!-- Main dashboard card -->
          <div
            class="rounded-3xl overflow-hidden shadow-2xl"
            style="background: white; border: 1px solid rgba(255,255,255,0.2);"
          >
            <!-- Header bar -->
            <div class="px-5 py-4 flex items-center justify-between" style="background: #1a3a5c;">
              <div class="flex items-center gap-3">
                <div
                  class="w-7 h-7 rounded-lg flex items-center justify-center"
                  style="background: rgba(255,255,255,0.2);"
                >
                  <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="2"
                  >
                    <rect x="2" y="2" width="9" height="9" rx="1"></rect><rect
                      x="13"
                      y="2"
                      width="9"
                      height="9"
                      rx="1"></rect><rect x="13" y="13" width="9" height="9" rx="1"></rect><rect
                      x="2"
                      y="13"
                      width="9"
                      height="9"
                      rx="1"></rect>
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold text-white">MARLO Reporting Dashboard</div>
                  <div class="text-[10px]" style="color: rgba(255,255,255,0.6);">
                    Annual Reporting Cycle · 2025
                  </div>
                </div>
              </div>
              <!-- Traffic lights -->
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full" style="background: rgba(248,113,113,0.7);">
                </div>
                <div class="w-2.5 h-2.5 rounded-full" style="background: rgba(250,204,21,0.7);">
                </div>
                <div class="w-2.5 h-2.5 rounded-full" style="background: rgba(74,222,128,0.7);">
                </div>
              </div>
            </div>

            <!-- Dashboard body -->
            <div class="bg-white p-5 flex flex-col gap-4">
              <!-- Portfolio progress bars -->
              <div>
                <div
                  class="text-[10px] font-semibold mb-3 tracking-wider uppercase"
                  style="color: #9ca3af;"
                >
                  Portfolio Completion
                </div>
                {
                  [
                    { label: 'Program A', pct: 87, color: '#2E86C1' },
                    { label: 'Program B', pct: 92, color: '#1A7A4A' },
                    { label: 'Program C', pct: 78, color: '#9A7D0A' },
                    { label: 'Program D', pct: 95, color: '#2E86C1' },
                  ].map(({ label, pct, color }) => (
                    <div class="flex items-center gap-3 mb-2">
                      <div class="text-xs w-16 shrink-0" style="color: #6b7280;">
                        {label}
                      </div>
                      <div class="flex-1 h-1.5 rounded-full" style="background: #e5e7eb;">
                        <div
                          class="h-1.5 rounded-full"
                          style={`width: ${pct}%; background: ${color};`}
                        />
                      </div>
                      <div class="text-xs font-semibold w-8 text-right" style="color: #111827;">
                        {pct}%
                      </div>
                    </div>
                  ))
                }
              </div>

              <!-- Mini stats grid -->
              <div class="grid grid-cols-3 gap-2">
                {
                  [
                    {
                      label: 'Reports',
                      value: '142',
                      color: '#2E86C1',
                      icon: `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/>`,
                    },
                    {
                      label: 'Indicators',
                      value: '64',
                      color: '#1A7A4A',
                      icon: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
                    },
                    {
                      label: 'Teams',
                      value: '12',
                      color: '#9A7D0A',
                      icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
                    },
                  ].map(({ label, value, color, icon }) => (
                    <div class="rounded-xl p-3 text-center" style="background: #f9fafb;">
                      <svg
                        class="mx-auto mb-1"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke={color}
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <Fragment set:html={icon} />
                      </svg>
                      <div class="text-lg font-semibold" style={`color: #111827;`}>
                        {value}
                      </div>
                          <div class="text-[10px]" style="color: #9ca3af;">
                        {label}
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>

          <!-- Floating card 1: Innovation alert (top-right) -->
          <div
            class="absolute -top-2 -right-2 rounded-2xl px-4 py-3 w-52 shadow-lg hero-float-card-1"
            style="background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.8);"
          >
            <div class="flex items-center gap-2 mb-1.5">
              <div
                class="w-6 h-6 rounded-lg flex items-center justify-center"
                style="background: #EAFAF1;"
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#1A7A4A"
                  stroke-width="2"
                >
                  <line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"
                  ></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line
                    x1="16.24"
                    y1="16.24"
                    x2="19.07"
                    y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line
                    x1="18"
                    y1="12"
                    x2="22"
                    y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line
                    x1="16.24"
                    y1="7.76"
                    x2="19.07"
                    y2="4.93"></line>
                </svg>
              </div>
              <span class="text-[11px] font-semibold" style="color: #111827;">Report Submitted</span>
            </div>
            <p class="text-[10px] leading-snug" style="color: #6b7280;">
              Q3 progress report validated and submitted by Program B
            </p>
            <div class="mt-2 text-[10px] font-semibold" style="color: #1A7A4A;">
              Status: Approved ↑
            </div>
          </div>

          <!-- Floating card 2: Report status (bottom-left) -->
          <div
            class="absolute -bottom-2 -left-2 rounded-2xl px-4 py-3 w-48 shadow-lg hero-float-card-2"
            style="background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.8);"
          >
            <div
              class="text-[10px] font-semibold mb-2 tracking-wide uppercase"
              style="color: #9ca3af;"
            >
              Report Status
            </div>
            <div class="flex flex-col gap-1.5">
              {
                [
                  { label: 'Submitted', count: 6, color: '#1A7A4A' },
                  { label: 'In Review', count: 2, color: '#9A7D0A' },
                ].map(({ label, count, color }) => (
                  <div class="flex items-center justify-between">
                    <span class="text-[11px]" style="color: #374151;">
                      {label}
                    </span>
                    <span class="text-[11px] font-bold" style={`color: ${color};`}>
                      {count}
                    </span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Floating card 3: Country badges (left-middle) -->
          <div
            class="absolute top-1/2 -left-4 -translate-y-1/2 rounded-xl px-3 py-2 shadow-lg hero-float-card-3"
            style="background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.8);"
          >
            <div class="text-[10px] font-semibold mb-1.5" style="color: #9ca3af;">Countries</div>
            <div class="flex gap-1">
              {
                ['US', 'UK', 'GH', 'IN', 'MX', 'BR'].map((c) => (
                  <span
                    class="w-6 h-6 rounded-full flex items-center justify-center text-white font-bold"
                    style="font-size: 0.5rem; background: #1B4F72;"
                  >
                    {c}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <!-- <div
      class="mt-16 pt-8 grid grid-cols-2 lg:grid-cols-4 gap-6"
      style="border-top: 1px solid rgba(255,255,255,0.1);"
    >
      {
        [
          { value: '9M+', label: 'People Reached' },
          { value: '41', label: 'Validated Innovations' },
          { value: '6', label: 'Country Teams' },
          { value: '$60M', label: 'World Bank Portfolio' },
        ].map(({ value, label }) => (
          <div class="flex flex-col gap-1">
            <span class="text-2xl font-bold text-white">{value}</span>
            <span class="text-xs" style="color: rgba(255,255,255,0.5);">
              {label}
            </span>
          </div>
        ))
      }
    </div> -->
  </div>
</section>
