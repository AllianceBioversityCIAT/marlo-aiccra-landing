---
const partners = [
  { name: 'Alliance of Bioversity & CIAT', src: '/logos/alliance.png' },
  { name: 'CGIAR', src: '/logos/cgiar.svg' },
  { name: 'World Bank', src: '/logos/world-bank.png' },
  { name: 'IFPRI', src: '/logos/ifpri.svg' },
  { name: 'ILRI', src: '/logos/ilri.svg', width: '80px' },
  { name: 'CIMMYT', src: '/logos/cimmyt.png', width: '200px' },
  { name: 'IITA', src: '/logos/iita.png' },
];
// Duplicate for seamless infinite loop
const loopItems = [...partners, ...partners];
---

<section class="bg-white py-12" style="border-bottom: 1px solid #e5e7eb;">
  <div class="max-w-7xl mx-auto px-6 flex items-center gap-10">
    <!-- Left label -->
    <p
      class="shrink-0 w-44 text-xs font-semibold leading-snug tracking-widest uppercase"
      style="color: #0d9488;"
    >
      Trusted Partners in Complex Program Environments
    </p>

    <!-- Carousel -->
    <div class="carousel-wrapper flex-1 overflow-hidden relative">
      <!-- Fade edges -->
      <div
        class="fade-left pointer-events-none absolute inset-y-0 left-0 z-10"
        style="width: 80px; background: linear-gradient(to right, white, transparent);"
      >
      </div>
      <div
        class="fade-right pointer-events-none absolute inset-y-0 right-0 z-10"
        style="width: 80px; background: linear-gradient(to left, white, transparent);"
      >
      </div>

      <div class="marquee-track flex items-center">
        {
          loopItems.map(({ name, src, width = 'auto' }) => (
            <div class="shrink-0 flex items-center justify-center pr-14">
              <img
                src={src}
                alt={name}
                class="object-contain grayscale opacity-60"
                style={`height: 50px; width: ${width};`}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-track {
    will-change: transform;
  }
</style>

<script>
  const track = document.querySelector('.marquee-track') as HTMLElement;
  if (track) {
    const SPEED = 60; // px/s
    let x = 0;
    let halfWidth = 0;
    let lastTime: number | null = null;

    const tick = (timestamp: number) => {
      if (!lastTime) lastTime = timestamp;
      x -= (SPEED * (timestamp - lastTime)) / 1000;
      lastTime = timestamp;

      // Seamless reset: position -halfWidth is visually identical to 0
      if (halfWidth > 0 && x <= -halfWidth) x += halfWidth;

      track.style.transform = `translateX(${x}px)`;
      requestAnimationFrame(tick);
    };

    window.addEventListener('load', () => {
      halfWidth = track.scrollWidth / 2;
      requestAnimationFrame(tick);
    });
  }
</script>
