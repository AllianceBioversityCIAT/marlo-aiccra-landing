---
const steps = [
  {
    num: '01',
    title: 'Strategic Planning',
    desc: 'Define outcomes, impact pathways, targets, and portfolio alignment across clusters.',
    icon: `<path d="M3 6l6-3 6 3 6-3v15l-6 3-6-3-6 3V6z"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>`,
    color: '#1a3a5c',
    bg: 'rgba(219,234,254,0.6)',
    stroke: '#2563eb',
  },
  {
    num: '02',
    title: 'Implementation & Monitoring',
    desc: 'Track activities, milestones, and deliverables across clusters in real time.',
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
    color: '#1a3a5c',
    bg: 'rgba(219,234,254,0.6)',
    stroke: '#2563eb',
  },
  {
    num: '03',
    title: 'Adaptive Review',
    desc: 'Document planning adjustments and reflect on strategic shifts with full audit trails.',
    icon: `<path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9"/>`,
    color: '#0d9488',
    bg: 'rgba(209,250,229,0.6)',
    stroke: '#0d9488',
  },
  {
    num: '04',
    title: 'Reporting & Learning',
    desc: 'Generate structured reports and synthesize insights at cluster and portfolio levels.',
    icon: `<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>`,
    color: '#92400e',
    bg: 'rgba(254,243,199,0.6)',
    stroke: '#d97706',
  },
];
---

<section id="lifecycle" class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
        Platform Lifecycle
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="color: #111827;">
        From Planning to Learning
      </h2>
      <p class="text-base max-w-lg mx-auto" style="color: #6b7280;">
        The platform preserves institutional memory while enabling adaptive, forward-looking management.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden lg:block absolute top-10 left-0 right-0 h-0.5 z-0" style="background: linear-gradient(to right, #2563eb, #2563eb 50%, #0d9488 50%, #0d9488); margin: 0 12%;">
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 relative z-10">
        {steps.map(({ num, title, desc, icon, bg, stroke }) => (
          <div class="flex flex-col items-center text-center gap-4">
            <!-- Icon box -->
            <div
              class="w-20 h-20 rounded-2xl flex flex-col items-center justify-center gap-1 shadow-sm"
              style={`background: ${bg}; border: 1px solid rgba(0,0,0,0.06);`}
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={stroke} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={icon} />
              </svg>
              <span class="text-xs font-bold" style={`color: ${stroke};`}>{num}</span>
            </div>
            <!-- Text -->
            <div>
              <h3 class="text-base font-bold mb-2" style="color: #111827;">{title}</h3>
              <p class="text-xs leading-relaxed" style="color: #6b7280;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Continuous cycle note -->
    <div class="flex justify-center mt-12">
      <div class="inline-flex items-center gap-2 px-6 py-3 rounded-full" style="background: #f3f4f6; border: 1px solid #e5e7eb;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2">
          <path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9"/>
        </svg>
        <span class="text-sm font-medium" style="color: #4b5563;">Continuous cycle — each phase informs the next</span>
      </div>
    </div>
  </div>
</section>
