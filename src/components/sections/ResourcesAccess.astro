---
const topCards = [
  {
    icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'Technical Documentation',
    desc: 'Architecture, DevOps, system governance, and integration guidance for platform administrators.',
    linkLabel: 'View Documentation →',
    linkColor: '#2563eb',
  },
  {
    icon: `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'User Guidelines',
    desc: 'Step-by-step operational guidance for planning and reporting cycles across all cluster roles.',
    linkLabel: 'Read Guidelines →',
    linkColor: '#2563eb',
  },
  {
    icon: `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
    iconColor: '#059669',
    iconBg: 'rgba(5,150,105,0.1)',
    title: 'Innovation Reporting Guide',
    desc: 'Best practices for documenting and showcasing innovation outcomes for donors and partners.',
    linkLabel: 'Access Guide →',
    linkColor: '#059669',
  },
];

const bottomCards = [
  {
    icon: `<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
    iconColor: '#ca8a04',
    iconBg: 'rgba(202,138,4,0.1)',
    title: 'FAQ',
    desc: 'Common questions about platform use, reporting expectations, and cycle management.',
    linkLabel: 'Browse FAQ →',
    linkColor: '#ca8a04',
  },
  {
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
    iconColor: '#1a3a5c',
    iconBg: 'rgba(26,58,92,0.1)',
    title: 'Support',
    desc: 'Contact the MARLO support team for technical assistance, access requests, or reporting queries.',
    linkLabel: 'Get Support →',
    linkColor: '#1a3a5c',
  },
];
---

<section id="resources" style="background: #f3f4f6;" class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-12">
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
          Resources &amp; Access
        </p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #111827;">
          Everything You Need to Get Started
        </h2>
      </div>
      <div class="flex items-center">
        <p class="text-sm leading-relaxed" style="color: #4b5563;">
          Comprehensive support materials for research managers, cluster leads, and platform administrators.
        </p>
      </div>
    </div>

    <!-- Top row: 3 cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      {topCards.map(({ icon, iconColor, iconBg, title, desc, linkLabel, linkColor }) => (
        <div class="bg-white rounded-2xl p-6 flex flex-col gap-4" style="border: 1px solid #e5e7eb;">
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center"
            style={`background: ${iconBg};`}
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icon} />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-base font-bold mb-2" style="color: #111827;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #6b7280;">{desc}</p>
          </div>
          <a
            href="#"
            class="text-sm font-semibold hover:underline transition-colors"
            style={`color: ${linkColor};`}
          >
            {linkLabel}
          </a>
        </div>
      ))}
    </div>

    <!-- Bottom row: 2 wide cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {bottomCards.map(({ icon, iconColor, iconBg, title, desc, linkLabel, linkColor }) => (
        <div class="bg-white rounded-2xl p-6 flex gap-5" style="border: 1px solid #e5e7eb;">
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
            style={`background: ${iconBg};`}
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icon} />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-base font-bold mb-1.5" style="color: #111827;">{title}</h3>
            <p class="text-sm leading-relaxed mb-3" style="color: #6b7280;">{desc}</p>
            <a
              href="#"
              class="text-sm font-semibold hover:underline"
              style={`color: ${linkColor};`}
            >
              {linkLabel}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
