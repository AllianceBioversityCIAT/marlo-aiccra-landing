---
const problems = [
  {
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10,9 9,9 8,9"/>`,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'Fragmented Reporting',
    desc: 'Multiple reporting formats across projects reduce comparability and strategic insight.',
  },
  {
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/>`,
    iconColor: '#f59e0b',
    iconBg: 'rgba(245,158,11,0.1)',
    title: 'Administrative Burden',
    desc: 'Manual consolidation processes consume time without generating actionable intelligence.',
  },
  {
    icon: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`,
    iconColor: '#dc2626',
    iconBg: 'rgba(220,38,38,0.1)',
    title: 'Limited Traceability',
    desc: 'Weak linkage between activities, outputs, and long-term outcomes undermines accountability.',
  },
  {
    icon: `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`,
    iconColor: '#7c3aed',
    iconBg: 'rgba(124,58,237,0.1)',
    title: 'Innovation Visibility Gaps',
    desc: 'Innovations are documented inconsistently, limiting scaling potential and donor visibility.',
  },
];
---

<section id="challenges" style="background: #f3f4f6;" class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
        The Strategic Challenge
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold" style="color: #111827;">
        The Challenge of Managing<br />Research for Impact
      </h2>
    </div>

    <!-- Problem cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
      {problems.map(({ icon, iconColor, iconBg, title, desc }) => (
        <div class="bg-white rounded-2xl p-6 flex gap-4" style="border: 1px solid #e5e7eb;">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5"
            style={`background: ${iconBg};`}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icon} />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-semibold mb-1.5" style="color: #111827;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #6b7280;">{desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Quote highlight -->
    <div class="rounded-2xl p-10 text-center" style="background: #1a3a5c;">
      <div class="flex justify-center mb-4">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="1.5">
          <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
          <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" style="transform: scale(0.5) translate(12px, 12px);"/>
        </svg>
      </div>
      <p class="text-xl lg:text-2xl font-medium text-white max-w-3xl mx-auto leading-relaxed">
        MARLO transforms reporting from a compliance requirement into a{' '}
        <em style="color: #60a5fa;">strategic portfolio intelligence system.</em>
      </p>
    </div>
  </div>
</section>
