---
import { FileText, Clock, Link2, EyeOff, Quote } from '@lucide/astro';

const problems = [
  {
    Icon: FileText,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'Scattered Data',
    desc: 'Data is scattered across Excel files, emails, and disconnected tools — making consolidation slow and error-prone.',
  },
  {
    Icon: Clock,
    iconColor: '#f59e0b',
    iconBg: 'rgba(245,158,11,0.1)',
    title: 'Manual Processes',
    desc: 'Reporting processes are manual, time-consuming, and prone to errors that compromise data reliability.',
  },
  {
    Icon: Link2,
    iconColor: '#dc2626',
    iconBg: 'rgba(220,38,38,0.1)',
    title: 'Inconsistent Standards',
    desc: 'Lack of standardized structures leads to inconsistent and incomparable data across teams and projects.',
  },
  {
    Icon: EyeOff,
    iconColor: '#7c3aed',
    iconBg: 'rgba(124,58,237,0.1)',
    title: 'Delayed Decisions',
    desc: 'Decision-making is delayed due to limited visibility and unreliable or outdated data across the portfolio.',
  },
];
---

<section
  id="challenges"
  class="py-24 relative"
  style="background-image: url('/images/impact-bg.jpg'); background-size: cover; background-position: center;"
>
  <div class="absolute inset-0" style="background: rgba(15, 42, 71, 0.78);"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #60A5FA;">
        The Problem
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="color: #ffffff;">
        Reporting is often fragmented<br />and inefficient
      </h2>
      <p class="text-sm leading-relaxed max-w-2xl" style="color: rgba(255,255,255,0.75);">
        Many programs face challenges when managing reporting across multiple teams, countries, and
        systems:
      </p>
    </div>

    <!-- Problem cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
      {
        problems.map(({ Icon, iconColor, iconBg, title, desc }) => (
          <div
            class="bg-black/30 backdrop-blur-sm rounded-2xl p-6 flex gap-4"
            style="border: 1px solid rgba(0,0,0,0.15);"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5"
              style={`background: ${iconBg};`}
            >
              <Icon size={18} color={iconColor} />
            </div>
            <div>
              <h3 class="text-base font-semibold mb-1.5" style="color: #ffffff;">
                {title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.75);">
                {desc}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Quote highlight -->
    <div
      class="bg-white/10 backdrop-blur-sm rounded-2xl p-10 text-center"
      style="border: 1px solid rgba(255,255,255,0.15);"
    >
      <div class="flex justify-center mb-4">
        <Quote size={28} color="#fbbf24" />
      </div>
      <p class="text-xl lg:text-2xl font-medium text-white max-w-3xl mx-auto leading-relaxed">
        MARLO addresses these challenges by providing a{' '}
        <em style="color: #60a5fa;">structured, centralized, and scalable solution.</em>
      </p>
    </div>
  </div>
</section>
