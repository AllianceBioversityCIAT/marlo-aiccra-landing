---
import {
  Palette,
  Code2,
  Database,
  Briefcase,
  Globe,
  Server,
  Shield,
  Puzzle,
  GitBranch,
  RefreshCw,
  MessageSquare,
  Activity,
  ArrowRight,
  Users,
} from '@lucide/astro';

const team = [
  {
    Icon: Palette,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'Product Design (UX/UI)',
    desc: 'Crafting intuitive interfaces tailored to the needs of program managers and reporting teams working in complex environments.',
  },
  {
    Icon: Code2,
    iconColor: '#0d9488',
    iconBg: 'rgba(13,148,136,0.1)',
    title: 'Software Development',
    desc: 'Building robust, scalable software with modern web technologies to support multi-country programs and large data volumes.',
  },
  {
    Icon: Database,
    iconColor: '#7c3aed',
    iconBg: 'rgba(124,58,237,0.1)',
    title: 'Data Management',
    desc: 'Ensuring data quality, consistency, and governance across complex program portfolios and reporting frameworks.',
  },
  {
    Icon: Briefcase,
    iconColor: '#f59e0b',
    iconBg: 'rgba(245,158,11,0.1)',
    title: 'Program Management',
    desc: 'Deep expertise in international program operations, enabling MARLO to align closely with real-world reporting workflows.',
  },
];

const techStack = [
  {
    Icon: Globe,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'Web-Based Platform',
    desc: 'Cloud-enabled and accessible from any device, eliminating infrastructure barriers for distributed teams.',
  },
  {
    Icon: Server,
    iconColor: '#0d9488',
    iconBg: 'rgba(13,148,136,0.1)',
    title: 'Scalable Architecture',
    desc: 'Designed to support multi-country programs as they grow in partners, geographies, and reporting complexity.',
  },
  {
    Icon: Shield,
    iconColor: '#dc2626',
    iconBg: 'rgba(220,38,38,0.1)',
    title: 'Secure Data Management',
    desc: 'Role-based access control and secure data management practices protect sensitive program information.',
  },
  {
    Icon: Puzzle,
    iconColor: '#7c3aed',
    iconBg: 'rgba(124,58,237,0.1)',
    title: 'API-Ready Integrations',
    desc: 'Open integration layer allows MARLO to connect with external systems, tools, and data sources as needed.',
  },
];

const devops = [
  {
    Icon: GitBranch,
    iconColor: '#f59e0b',
    iconBg: 'rgba(245,158,11,0.1)',
    title: 'Agile Development',
    desc: 'Iterative sprints and close collaboration with users allow MARLO to adapt quickly to evolving program needs.',
  },
  {
    Icon: RefreshCw,
    iconColor: '#0d9488',
    iconBg: 'rgba(13,148,136,0.1)',
    title: 'CI/CD Pipeline',
    desc: 'Continuous integration and deployment ensure reliable releases with minimal downtime and rapid feature delivery.',
  },
  {
    Icon: MessageSquare,
    iconColor: '#2563eb',
    iconBg: 'rgba(37,99,235,0.1)',
    title: 'User-Driven Improvements',
    desc: 'Feedback loops with program teams drive iterative enhancements, keeping the platform aligned with real usage.',
  },
  {
    Icon: Activity,
    iconColor: '#7c3aed',
    iconBg: 'rgba(124,58,237,0.1)',
    title: 'Monitoring & Performance',
    desc: 'Proactive monitoring and performance optimization ensure platform reliability at scale.',
  },
];
---

<!-- Page header -->
<section
  class="relative py-20 overflow-hidden"
  style="background: #012E4A;"
>
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 32px 32px;"
  ></div>
  <div class="relative max-w-4xl mx-auto px-6 text-center flex flex-col items-center gap-5">
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold"
      style="background: rgba(37,99,235,0.2); color: #93c5fd; border: 1px solid rgba(37,99,235,0.3);"
    >
      <Users size={12} />
      TEAM & TECHNOLOGY
    </div>
    <h1 class="text-4xl lg:text-5xl font-bold text-white leading-tight">
      Built by experts, <em class="not-italic" style="color: #22D3EE;">designed for impact</em>
    </h1>
    <p class="text-base lg:text-lg leading-relaxed max-w-2xl" style="color: rgba(255,255,255,0.75);">
      MARLO is developed by a multidisciplinary team with experience working alongside international organizations and complex reporting environments.
    </p>
  </div>
</section>

<!-- Team section -->
<section style="background: #f3f4f6;" class="py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-12">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
        The Team
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-3" style="color: #111827;">
        Multidisciplinary expertise
      </h2>
      <p class="text-sm leading-relaxed max-w-2xl" style="color: #6b7280;">
        MARLO is developed by a team combining deep technical and domain knowledge across four core areas.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {team.map(({ Icon, iconColor, iconBg, title, desc }) => (
        <div class="bg-white rounded-2xl p-6 flex gap-4" style="border: 1px solid #e5e7eb;">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5"
            style={`background: ${iconBg};`}
          >
            <Icon size={18} color={iconColor} />
          </div>
          <div>
            <h3 class="text-base font-semibold mb-1.5" style="color: #111827;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #6b7280;">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Technology stack section -->
<section style="background: white;" class="py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-12">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
        Technology
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-3" style="color: #111827;">
        Stack & Architecture
      </h2>
      <p class="text-sm leading-relaxed max-w-2xl" style="color: #6b7280;">
        A modern, cloud-native foundation that supports the scale and security demands of international programs.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {techStack.map(({ Icon, iconColor, iconBg, title, desc }) => (
        <div class="rounded-2xl p-6 flex gap-4" style="background: #f3f4f6; border: 1px solid #e5e7eb;">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5"
            style={`background: ${iconBg};`}
          >
            <Icon size={18} color={iconColor} />
          </div>
          <div>
            <h3 class="text-base font-semibold mb-1.5" style="color: #111827;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #6b7280;">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- DevOps section -->
<section style="background: #f3f4f6;" class="py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-12">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
        DevOps
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-3" style="color: #111827;">
        How we build and ship
      </h2>
      <p class="text-sm leading-relaxed max-w-2xl" style="color: #6b7280;">
        Our development approach ensures reliability, speed, and continuous alignment with user needs.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-14">
      {devops.map(({ Icon, iconColor, iconBg, title, desc }) => (
        <div class="bg-white rounded-2xl p-6 flex gap-4" style="border: 1px solid #e5e7eb;">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5"
            style={`background: ${iconBg};`}
          >
            <Icon size={18} color={iconColor} />
          </div>
          <div>
            <h3 class="text-base font-semibold mb-1.5" style="color: #111827;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #6b7280;">{desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div
      class="rounded-2xl p-10 text-center flex flex-col items-center gap-5"
      style="background: #1a3a5c;"
    >
      <h3 class="text-2xl font-bold text-white">Interested in working with us?</h3>
      <p class="text-sm max-w-md" style="color: rgba(255,255,255,0.7);">
        Request a demo and explore how MARLO can support your program's reporting needs.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold transition-all"
        style="background: white; color: #1a3a5c;"
        onmouseover="this.style.backgroundColor='#f0f9ff'"
        onmouseout="this.style.backgroundColor='white'"
      >
        Request a Demo
        <ArrowRight size={15} />
      </a>
    </div>
  </div>
</section>
