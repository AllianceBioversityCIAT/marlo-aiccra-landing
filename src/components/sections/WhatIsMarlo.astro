---
---

<section id="platform" class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #0d9488;">
        What is MARLO AICCRA
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-6" style="color: #111827;">
        A Platform Built for Research That Matters
      </h2>
      <p class="text-base leading-relaxed max-w-2xl" style="color: #4b5563;">
        MARLO (Managing Agricultural Research for Learning and Outcomes) is an online platform that
        supports strategic, results-based planning and reporting across research clusters and portfolios.
        It enables coordinated reporting across distributed teams while consolidating program-level data
        for institutional oversight.
      </p>
    </div>

    <!-- Feature Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Large left card: Centralized Ecosystem -->
      <div class="rounded-2xl p-8 flex flex-col gap-6" style="background: #f3f4f6; border: 1px solid #e5e7eb;">
        <!-- Icon -->
        <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(37,99,235,0.1);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2">
            <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
          </svg>
        </div>

        <div>
          <h3 class="text-xl font-bold mb-3" style="color: #111827;">Centralized Yet Distributed Ecosystem</h3>
          <p class="text-sm leading-relaxed" style="color: #6b7280;">
            Enables multiple research clusters to operate independently while maintaining centralized visibility and portfolio-level consolidation.
          </p>
        </div>

        <!-- Country badges visualization -->
        <div class="rounded-xl p-6 bg-white" style="border: 1px solid #e5e7eb;">
          <div class="flex flex-wrap gap-3 justify-center mb-3">
            {[
              { code: 'SE', label: 'Senegal' },
              { code: 'ET', label: 'Ethiopia' },
              { code: 'KE', label: 'Kenya' },
              { code: 'GH', label: 'Ghana' },
              { code: 'MA', label: 'Mali' },
              { code: 'ZA', label: 'Zambia' },
            ].map(({ code, label }) => (
              <div class="flex flex-col items-center gap-1.5">
                <div
                  class="w-12 h-12 rounded-xl flex items-center justify-center text-sm font-bold text-white"
                  style="background: #1a3a5c;"
                >
                  {code}
                </div>
                <span class="text-[10px] text-center" style="color: #9ca3af;">{label}</span>
              </div>
            ))}
            <div class="flex flex-col items-center gap-1.5">
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center text-xs font-bold text-white"
                style="background: #2563eb;"
              >
                CGIAR
              </div>
              <span class="text-[10px] text-center" style="color: #9ca3af;">Portfolio</span>
            </div>
          </div>
          <div class="flex items-center justify-end gap-1 mt-2">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
              <polyline points="18,15 12,9 6,15"/>
            </svg>
            <span class="text-xs" style="color: #9ca3af;">Centralized consolidation</span>
          </div>
        </div>
      </div>

      <!-- Right: two stacked cards -->
      <div class="flex flex-col gap-6">
        <!-- Full Lifecycle Management -->
        <div class="rounded-2xl p-8 bg-white flex flex-col gap-4 flex-1" style="border: 1px solid #e5e7eb;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(13,148,136,0.1);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2">
              <path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #111827;">Full Lifecycle Management</h3>
            <p class="text-sm leading-relaxed" style="color: #6b7280;">
              Covers the entire project cycle — from strategic planning and activity definition to outcome reporting and learning.
            </p>
          </div>
        </div>

        <!-- Outcome-Focused Reporting -->
        <div class="rounded-2xl p-8 bg-white flex flex-col gap-4 flex-1" style="border: 1px solid #e5e7eb;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(234,179,8,0.1);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ca8a04" stroke-width="2">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #111827;">Outcome-Focused Reporting</h3>
            <p class="text-sm leading-relaxed" style="color: #6b7280;">
              Aligns deliverables and innovations with defined impact pathways and measurable results.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
